# =========================================================================
#  Only track integrated_pipeline/ — everything else in this repo is ignored
# =========================================================================
/*
!/integrated_pipeline

# =========================================================================
#  Standard ignores (applied within integrated_pipeline/)
# =========================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/
.env/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Jupyter Notebook
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Environment variables
.env
.env.local

# pytest
.pytest_cache/

# Claude Code
.claude/
